# Kconfig for `iotmer_ble_wifi_prov` — must live in this component so symbols exist in sdkconfig
# whenever the component is part of the build (CMake uses CONFIG_IOTMER_BLE_WIFI_PROV).

if SOC_BT_SUPPORTED

menu "IOTMER BLE Wi-Fi provisioning (GATT v1)"

config IOTMER_BLE_WIFI_PROV
    bool "Compile IOTMER BLE Wi-Fi provisioning module (NimBLE)"
    default n
    help
        When enabled, this component links the IOTMER-defined GATT protocol (v1) for Wi-Fi credential transfer.
        Applications must still enable NimBLE in sdkconfig and add `REQUIRES iotmer_ble_wifi_prov`.

config IOTMER_BLE_ADV_TIMEOUT_MS
    int "BLE provisioning: advertising timeout (ms, 0 = until stop())"
    default 300000
    depends on IOTMER_BLE_WIFI_PROV
    help
        After `iotmer_ble_wifi_prov_start()`, advertising stops automatically when this elapses
        with no active GATT connection. Set 0 to advertise until `stop()` or connection handling.

config IOTMER_BLE_CONN_IDLE_MS
    int "BLE provisioning: connected idle timeout (ms)"
    default 120000
    depends on IOTMER_BLE_WIFI_PROV
    help
        If no valid Control/Data write resets the idle timer for this long, the session aborts.

config IOTMER_BLE_SESSION_MAX_MS
    int "BLE provisioning: maximum session duration after connect (ms)"
    default 600000
    depends on IOTMER_BLE_WIFI_PROV
    help
        Hard cap from first GATT activity after connection; forces teardown even if idle timer keeps resetting.

config IOTMER_BLE_ADV_NAME_PREFIX
    string "BLE provisioning: GAP device name prefix"
    default "IOTMER-"
    depends on IOTMER_BLE_WIFI_PROV
    help
        Full advertised name is prefix + short hex suffix (MAC-derived). Do not put secrets in the name.

config IOTMER_BLE_RESTART_ADV_ON_DISCONNECT
    bool "BLE provisioning: resume advertising after disconnect (until stop/timeout)"
    default y
    depends on IOTMER_BLE_WIFI_PROV
    help
        When y, a dropped link during an active `start()` window resumes connectable advertising
        until advertising timeout or `iotmer_ble_wifi_prov_stop()`.

config IOTMER_BLE_SMP_IO_CAP
    int "BLE SMP IO capability (NimBLE ble_hs_cfg.sm_io_cap)"
    default 3
    depends on IOTMER_BLE_WIFI_PROV
    range 0 4
    help
        0=DISPLAY_ONLY, 1=DISPLAY_YESNO, 2=KEYBOARD_ONLY, 3=NO_IO (Just Works default), 4=KEYBOARD_DISP.
        Passkey flows require app/firmware UI; defaults stay NO_IO.

endmenu

endif # SOC_BT_SUPPORTED
