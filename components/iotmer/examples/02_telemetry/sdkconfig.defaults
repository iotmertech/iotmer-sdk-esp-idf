CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# Debug (-Og) exceeds 1 MiB app slots with TWO_OTA + mbedTLS bundle; -Os fits comfortably.
CONFIG_COMPILER_OPTIMIZATION_SIZE=y

CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_PARTITION_TABLE_TWO_OTA=y

# HTTPS provisioning + MQTT TLS need the Mozilla CA bundle (esp_crt_bundle_attach).
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_CROSS_SIGNED_VERIFY=y

# Provisioning + MQTT on app_main need extra stack for mbedTLS.
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

CONFIG_ESP_TASK_WDT_TIMEOUT_S=30

CONFIG_IOTMER_WIFI_SSID=""
CONFIG_IOTMER_WIFI_PASSWORD=""

CONFIG_IOTMER_PROVISION_AUTH_CODE=""
CONFIG_IOTMER_WORKSPACE_ID=""
CONFIG_IOTMER_WORKSPACE_SLUG=""
CONFIG_IOTMER_TEMPLATE_ID=""

