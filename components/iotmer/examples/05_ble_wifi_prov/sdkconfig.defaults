CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_COMPILER_OPTIMIZATION_SIZE=y
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
# Default 1 MB app slot is too small for BT + iotmer + cJSON (link ~1.12 MB).
CONFIG_PARTITION_TABLE_SINGLE_APP_LARGE=y

CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_ESP_TASK_WDT_TIMEOUT_S=30

CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=1
CONFIG_BT_NIMBLE_ROLE_PERIPHERAL=y
CONFIG_BT_NIMBLE_ROLE_BROADCASTER=y

CONFIG_IOTMER_BLE_WIFI_PROV=y

# HTTPS (iotmer_provision, bind-claim) + MQTT TLS — same as examples/01_provisioning.
# Without FULL + CROSS_SIGNED, esp_crt_bundle may fail handshake to console.iotmer.com
# ("No matching trusted root certificate found") when bind-claim runs after provision skip.
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_CROSS_SIGNED_VERIFY=y

CONFIG_IOTMER_WIFI_SSID=""
CONFIG_IOTMER_WIFI_PASSWORD=""

CONFIG_IOTMER_PROVISION_AUTH_CODE=""
CONFIG_IOTMER_WORKSPACE_ID=""
CONFIG_IOTMER_WORKSPACE_SLUG=""
CONFIG_IOTMER_TEMPLATE_ID=""
